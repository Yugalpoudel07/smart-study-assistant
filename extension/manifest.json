{
  "manifest_version": 3,
  "name": "Smart Study Assistant",
  "version": "1.1",
  "description": "AI-powered study helper for students with improved UI",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "host_permissions": ["http://127.0.0.1:8000/*"]
}