{
  "manifest_version": 3,
  "name": "Smart Study Assistant",
  "version": "1.0",
  "description": "AI-powered study helper — simplify text, generate questions, extract keywords, detect difficulty, study notes, history & PDF export",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "host_permissions": ["http://127.0.0.1:8000/*"],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
