{
  "manifest_version": 3,
  "name": "Smart Study Assistant",
  "version": "3.1",
  "description": "Select any text on a webpage to get an AI-powered simplified explanation, practice questions, keywords, and difficulty rating.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "https://smart-study-assistant-api.onrender.com/*"
  ],

  "action": {
    "default_icon": {
      "48": "icon.png",
      "128": "icon.png"
    },
    "default_title": "Smart Study Assistant"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  },

  "minimum_chrome_version": "102",

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  }
}
